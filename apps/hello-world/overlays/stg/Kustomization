apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

resources:
  - ../../base

namespace: stg
namePrefix: stg-

# Modificamos la cantidad de réplicas del Deployment original sobre la marcha
replicas:
  - name: hello-world-app
    count: 2

configMapGenerator:
- name: app-messages
  literals:
    - MESSAGE="Hola Alumnos de ITU - Estamos en el entorno de STAGING validando la app"
